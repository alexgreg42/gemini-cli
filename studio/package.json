{
  "name": "gemini-cli-studio",
  "productName": "Gemini CLI Studio",
  "private": true,
  "version": "1.0.0",
  "description": "Gemini CLI Studio — desktop interface for Gemini models",
  "author": "alexgreg42",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:electron": "npm run build && electron-builder --win --x64",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^24.12.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.38.0",
    "globals": "^17.6.0",
    "lucide-react": "^1.14.0",
    "prismjs": "^1.30.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.gemini.cli.studio",
    "productName": "Gemini CLI Studio",
    "copyright": "Copyright © 2026 Gemini CLI Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gemini CLI Studio",
      "installerLanguages": [
        "French",
        "English"
      ],
      "language": "1036"
    }
  }
}
